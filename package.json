{
  "name": "pos-system",
  "version": "1.0.0",
  "description": "نظام نقاط البيع - POS System",
  "main": "electron/main.js",
  "author": "POS Team",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "test": "playwright test",
    "test:ui": "playwright test --ui"
  },
  "build": {
    "appId": "com.pos.system",
    "productName": "POS System",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "asarUnpack": [
      "electron/sql-wasm.wasm"
    ],
    "publish": {
      "provider": "github",
      "owner": "AbdulrhmanMohamed",
      "repo": "POS"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "i18next": "^23.10.0",
    "i18next-browser-languagedetector": "^7.2.0",
    "jsbarcode": "^3.12.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^14.0.5",
    "recharts": "^3.8.1",
    "sql.js": "^1.14.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "pngjs": "^7.0.0",
    "vite": "^5.1.4"
  }
}
